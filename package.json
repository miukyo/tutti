{
  "name": "tutti",
  "description": "Tutti is a beautifully designed desktop client for YouTube Music",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "author": {
    "email": "zaidaliyhijja@gmail.com",
    "name": "Miukyo",
    "url": "https://miukyo.my.id"
  },
  "main": "packages/entry-point.mjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miukyo/tutti.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=23.0.0"
  },
  "scripts": {
    "build": "npm run build -ws --if-present",
    "compile": "npm run build && electron-builder build --config electron-builder.mjs",
    "start": "node packages/dev-mode.js",
    "typecheck": "npm run typecheck -ws --if-present"
  },
  "devDependencies": {
    "@npmcli/map-workspaces": "5.0.3",
    "@playwright/test": "1.58.2",
    "@types/node": "25.5.0",
    "create-vite": "9.0.3",
    "electron": "^41.10.0",
    "electron-builder": "26.8.1",
    "glob": "13.0.6",
    "playwright": "^1.58.2"
  },
  "dependencies": {
    "@app/main": "*"
  },
  "allowScripts": {
    "electron@41.0.3": true,
    "electron-winstaller@5.4.0": true,
    "globals": true
  }
}